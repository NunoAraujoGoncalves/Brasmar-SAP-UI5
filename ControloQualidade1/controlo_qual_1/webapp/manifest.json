{
  "_version": "1.6.0",
  "sap.app": {
    "id": "brasmar.bra.controloqualidade.controloqual1",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:lrop",
      "version": "1.19.3",
      "toolsId": "240ef22b-36d1-4703-b2c5-f8668eb5c94d"
    },
    "dataSources": {
      "annotation": {
        "type": "ODataAnnotation",
        "uri": "annotations/annotation.xml",
        "settings": {
          "localUri": "annotations/annotation.xml"
        }
      },
      "mainService": {
        "uri": "/sap/opu/odata4/sap/zui_tabcq_o4/srvd/sap/zui_tabcq_o4/0001/",
        "type": "OData",
        "settings": {
          "annotations": [
            "annotation"
          ],
          "localUri": "localService/mainService/metadata.xml",
          "odataVersion": "4.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.120.23",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "brasmar.bra.controloqualidade.controloqual1.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "resources": {
      "css": []
    },
    "routing": {
      "config": {},
      "routes": [
        {
          "pattern": ":?query:",
          "name": "CQCabList",
          "target": [
            "CQCabList"
          ]
        },
        {
          "pattern": "CQCab({key}):?query:",
          "name": "CQCabObjectPage",
          "target": [
            "CQCabList",
            "CQCabObjectPage"
          ]
        },
        {
          "pattern": "CQCab({key})/_linhas({key2}):?query:",
          "name": "CQLinhasObjectPage",
          "target": [
            "CQCabList",
            "CQCabObjectPage",
            "CQLinhasObjectPage"
          ]
        }
      ],
      "targets": {
        "CQCabList": {
          "type": "Component",
          "id": "CQCabList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/CQCab",
              "variantManagement": "Page",
              "navigation": {
                "CQCab": {
                  "detail": {
                    "route": "CQCabObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable"
                  }
                }
              },
              "hideFilterBar": false
            }
          }
        },
        "CQCabObjectPage": {
          "type": "Component",
          "id": "CQCabObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/CQCab",
              "navigation": {
                "_linhas": {
                  "detail": {
                    "route": "CQLinhasObjectPage"
                  }
                }
              }
            }
          }
        },
        "CQLinhasObjectPage": {
          "type": "Component",
          "id": "CQLinhasObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/CQCab/_linhas"
            }
          }
        }
      }
    },
    "extends": {
      "extensions": {
        "sap.ui.controllerExtensions": {
          "sap.fe.templates.ListReport.ListReportController#brasmar.bra.controloqualidade.controloqual1::CQCabList": {
            "controllerName": "brasmar.bra.controloqualidade.controloqual1.ext.controller.CabListController"
          }
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  }
}
