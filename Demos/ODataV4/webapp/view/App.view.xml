<mvc:View
    controllerName="sap.ui.core.tutorial.odatav4.controller.App"
    displayBlock="true"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
>
    <Shell>
        <App
            busy="{appView>/busy}"
            class="sapUiSizeCompact"
        >
            <pages>
                <Page title="{i18n>peoplePageTitle}">
                    <content>
                        <Table
                            id="idPeopleTable"
                            growing="true"
                            growingThreshold="10"
                            items="{
								path: '/People',
                                parameters: { $count: true }
							}"
                        >
                            <headerToolbar>
                                <OverflowToolbar>
                                    <content>
                                        <ToolbarSpacer />
                                        <SearchField
											id="idSearchField"
											width="20%"
											placeholder="{i18n>searchFieldPlaceholder}"
											search=".onSearchFieldSearch"/>
                                        <Button
                                            id="idRefreshUsersButton"
                                            icon="sap-icon://refresh"
                                            tooltip="{i18n>refreshButtonText}"
                                            press=".onButtonPress"
                                        />
                                        <Button
											id="idSortUsersButton"
											icon="sap-icon://sort"
											tooltip="{i18n>sortButtonText}"
											press="onButtonSortPress"/>
                                    </content>
                                </OverflowToolbar>
                            </headerToolbar>
                            <columns>
                                <Column id="idUserNameColumn">
                                    <Text text="{i18n>userNameLabelText}" />
                                </Column>
                                <Column id="idFirstNameColumn">
                                    <Text text="{i18n>firstNameLabelText}" />
                                </Column>
                                <Column id="idLastNameColumn">
                                    <Text text="{i18n>lastNameLabelText}" />
                                </Column>
                                <Column id="idAgeColumn">
                                    <Text text="{i18n>ageLabelText}" />
                                </Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <Input value="{UserName}" />
                                    </cells>
                                    <cells>
                                        <Input value="{FirstName}" />
                                    </cells>
                                    <cells>
                                        <Input value="{LastName}" />
                                    </cells>
                                    <cells>
                                        <Input value="{Age}" />
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </content>
                </Page>
            </pages>
        </App>
    </Shell>
</mvc:View>
