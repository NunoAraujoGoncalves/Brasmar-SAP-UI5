{
  "_version": "1.60.0",
  "sap.app": {
    "id": "controlo.qualidade1.controloqualidade1",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:lrop",
      "version": "1.20.4",
      "toolsId": "1cdbf601-c669-4df1-a622-1772a597a946"
    },
    "dataSources": {
      "annotation": {
        "type": "ODataAnnotation",
        "uri": "annotations/annotation.xml",
        "settings": {
          "localUri": "annotations/annotation.xml"
        }
      },
      "mainService": {
        "uri": "/sap/opu/odata4/sap/zui_tabcq_o4/srvd/sap/zui_tabcq_o4/0001/",
        "type": "OData",
        "settings": {
          "annotations": [
            "annotation"
          ],
          "localUri": "localService/mainService/metadata.xml",
          "odataVersion": "4.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.120.23",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "controlo.qualidade1.controloqualidade1.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "resources": {
      "css": []
    },
    "routing": {
      "config": {},
      "routes": [
        {
          "pattern": ":?query:",
          "name": "CQCabList",
          "target": "CQCabList"
        },
        {
          "pattern": "CQCab({key}):?query:",
          "name": "CQCabObjectPage",
          "target": "CQCabObjectPage"
        },
        {
          "pattern": "CQCab({key})/_linhas({key2}):?query:",
          "name": "CQLinhasObjectPage",
          "target": "CQLinhasObjectPage"
        },
        {
          "name": "CQCab__HabBrasilObjectPage",
          "pattern": "CQCab({key})/_HabBrasil({_HabBrasilKey}):?query:",
          "target": "CQCab__HabBrasilObjectPage"
        },
        {
          "name": "CQCab__ingredientesObjectPage",
          "pattern": "CQCab({key})/_ingredientes({_ingredientesKey}):?query:",
          "target": "CQCab__ingredientesObjectPage"
        },
        {
          "name": "CQCab__nutricionaisObjectPage",
          "pattern": "CQCab({key})/_nutricionais({_nutricionaisKey}):?query:",
          "target": "CQCab__nutricionaisObjectPage"
        },
        {
          "name": "CQCab__alegerneosContemObjectPage",
          "pattern": "CQCab({key})/_alegerneosContem({_alegerneosContemKey}):?query:",
          "target": "CQCab__alegerneosContemObjectPage"
        },
        {
          "name": "CQCab__alegerneosPodeConterObjectPage",
          "pattern": "CQCab({key})/_alegerneosPodeConter({_alegerneosPodeConterKey}):?query:",
          "target": "CQCab__alegerneosPodeConterObjectPage"
        }
      ],
      "targets": {
        "CQCabList": {
          "type": "Component",
          "id": "CQCabList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/CQCab",
              "variantManagement": "Page",
              "navigation": {
                "CQCab": {
                  "detail": {
                    "route": "CQCabObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable"
                  }
                }
              }
            }
          }
        },
        "CQCabObjectPage": {
          "type": "Component",
          "id": "CQCabObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/CQCab",
              "navigation": {
                "_linhas": {
                  "detail": {
                    "route": "CQLinhasObjectPage"
                  }
                },
                "_HabBrasil": {
                  "detail": {
                    "route": "CQCab__HabBrasilObjectPage"
                  }
                },
                "_ingredientes": {
                  "detail": {
                    "route": "CQCab__ingredientesObjectPage"
                  }
                },
                "_nutricionais": {
                  "detail": {
                    "route": "CQCab__nutricionaisObjectPage"
                  }
                },
                "_alegerneosContem": {
                  "detail": {
                    "route": "CQCab__alegerneosContemObjectPage"
                  }
                },
                "_alegerneosPodeConter": {
                  "detail": {
                    "route": "CQCab__alegerneosPodeConterObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "_HabBrasil/@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "creationMode": {
                      "name": "InlineCreationRows"
                    }
                  }
                },
                "_ingredientes/@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "creationMode": {
                      "name": "InlineCreationRows"
                    }
                  }
                },
                "_alegerneosContem/@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "creationMode": {
                      "name": "InlineCreationRows"
                    }
                  }
                },
                "_alegerneosPodeConter/@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "creationMode": {
                      "name": "InlineCreationRows"
                    }
                  }
                }
              }
            }
          }
        },
        "CQLinhasObjectPage": {
          "type": "Component",
          "id": "CQLinhasObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/CQCab/_linhas",
              "controlConfiguration": {
                "_PesosCX/@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "creationMode": {
                      "name": "Inline"
                    }
                  },
                  "columns": {
                    "Balanca": {
                      "header": "{i18n>balanca}",
                      "position": {
                        "anchor": "DataField::Pb",
                        "placement": "Before"
                      },
                      "template": "controlo.qualidade1.controloqualidade1.ext.fragment.Balanca"
                    }
                  }
                },
                "_PesosUn/@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "creationMode": {
                      "name": "Inline"
                    }
                  }
                },
                "_Vidragens/@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "creationMode": {
                      "name": "Inline"
                    }
                  }
                },
                "_Calibres/@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "creationMode": {
                      "name": "Inline"
                    }
                  }
                },
                "_Temperaturas/@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "creationMode": {
                      "name": "InlineCreationRows"
                    }
                  }
                }
              }
            }
          }
        },
        "CQCab__HabBrasilObjectPage": {
          "type": "Component",
          "id": "CQCab__HabBrasilObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "navigation": {},
              "contextPath": "/CQCab/_HabBrasil"
            }
          }
        },
        "CQCab__ingredientesObjectPage": {
          "type": "Component",
          "id": "CQCab__ingredientesObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "navigation": {},
              "contextPath": "/CQCab/_ingredientes"
            }
          }
        },
        "CQCab__nutricionaisObjectPage": {
          "type": "Component",
          "id": "CQCab__nutricionaisObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "navigation": {},
              "contextPath": "/CQCab/_nutricionais"
            }
          }
        },
        "CQCab__alegerneosContemObjectPage": {
          "type": "Component",
          "id": "CQCab__alegerneosContemObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "navigation": {},
              "contextPath": "/CQCab/_alegerneosContem"
            }
          }
        },
        "CQCab__alegerneosPodeConterObjectPage": {
          "type": "Component",
          "id": "CQCab__alegerneosPodeConterObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "navigation": {},
              "contextPath": "/CQCab/_alegerneosPodeConter"
            }
          }
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  },
  "sap.fe": {
    "app": {
      "enableLazyLoading": true
    }
  }
}
